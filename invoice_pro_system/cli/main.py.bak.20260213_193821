        if len(args.id) != 13 or not args.id.isdigit():
            print(f"❌ Error: ID must be 13 digits")
            return 1
        
        customer_id = service.create_customer(
            name=args.name,
            surname=args.surname,
            id_number=args.id,
            company=args.company,
            email=args.email,
            phone=args.phone
        )
        
        return 0 if customer_id else 1
    except Exception as e:
        print(f"❌ Error adding customer: {e}")
