def handle_invoice_view(args):
    """View invoice details."""
    try:
        from services.invoice_service import InvoiceService
        
        service = InvoiceService()
        invoice = service.get_invoice(args.id)
        
        if not invoice:
            print(f"❌ Invoice {args.id} not found")
            return 1
        
        # Display invoice
        print("\n" + "=" * 70)
        print(f"🧾 INVOICE #{invoice['invoice_number']}")
        print("=" * 70)
        
        # Customer info
        print(f"\n📋 Customer:")
        print(f"   {invoice.get('customer_name', '')} {invoice.get('customer_surname', '')}")
        if invoice.get('customer_company'):
            print(f"   {invoice['customer_company']}")
        print(f"   ID: {invoice.get('customer_id_number', 'N/A')}")
        print(f"   Email: {invoice.get('customer_email', 'N/A')}")
        
        # Invoice details
        print(f"\n📅 Details:")
        print(f"   Date: {invoice.get('invoice_date', '')[:10]}")
        print(f"   Due: {invoice.get('due_date', '')[:10] if invoice.get('due_date') else 'N/A'}")
        print(f"   Status: {invoice.get('status', 'draft').upper()}")
        
        # Items
        print(f"\n📦 Items:")
        print("-" * 70)
        print(f"{'Description':<40} {'Qty':>6} {'Price':>10} {'Total':>12}")
        print("-" * 70)
        
        for item in invoice.get('items', []):
            desc = item['item_description'][:37] + "..." if len(item['item_description']) > 37 else item['item_description']
            print(f"{desc:<40} {item['quantity']:>6} R{item['unit_price']:>9,.2f} R{item['line_total']:>11,.2f}")
        
        print("-" * 70)
        print(f"{'Subtotal:':<58} R{invoice.get('subtotal', 0):>11,.2f}")
        print(f"{'VAT (15%):':<58} R{invoice.get('tax_amount', 0):>11,.2f}")
        print("=" * 70)
        print(f"{'TOTAL DUE:':<58} R{invoice.get('total_amount', 0):>11,.2f}")
        print("=" * 70)
        
        # Generate PDF if requested
        if args.pdf:
            try:
                from services.pdf_service import PDFInvoiceService
                pdf_service = PDFInvoiceService()
                pdf_service.generate_invoice_from_db(invoice)
            except ImportError:
                print("⚠️  PDF generation not available")
        
        return 0
    except Exception as e:
        print(f"❌ Error viewing invoice: {e}")
        return 1

