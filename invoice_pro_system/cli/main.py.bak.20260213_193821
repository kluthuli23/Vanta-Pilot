def handle_invoice_create(args):
    """Create a real invoice in database."""
    try:
        from services.invoice_service import InvoiceService
        
        service = InvoiceService()
        
        # Parse items
        items = []
        for item_str in args.items:
            try:
                desc, qty, price = item_str.split(':')
                items.append((desc, int(qty), float(price)))
            except ValueError:
                print(f"❌ Invalid item format: {item_str}")
                print("   Use: description:quantity:price")
                return 1
        
        invoice_id = service.create_invoice(
            customer_id=args.customer_id,
            items=items,
            description=args.description,
            due_days=args.due_days
        )
        
        if invoice_id and args.pdf:
            try:
                from services.pdf_service import PDFInvoiceService
                pdf_service = PDFInvoiceService()
                invoice = service.get_invoice(invoice_id)
                if invoice:
                    pdf_service.generate_invoice_from_db(invoice)
            except ImportError:
                print("⚠️  PDF generation not available")
                print("   Install reportlab: pip install reportlab")
        
        return 0 if invoice_id else 1
    except Exception as e:
        print(f"❌ Error creating invoice: {e}")
        return 1

