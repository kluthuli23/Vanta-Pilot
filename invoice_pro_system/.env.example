# .env.example

# Application
APP_NAME=InvoicePro
LOG_LEVEL=INFO
DEFAULT_CURRENCY=ZAR
VAT_RATE=0.15
INVOICE_PREFIX=INV

# Business
BUSINESS_NAME=Your Business Name
BUSINESS_VAT_NUMBER=

# Database
DB_NAME=business.db
DB_TIMEOUT=30
DB_PATH=invoice_pro_system/data/business.db

# Sessions
SESSION_SECRET_KEY=change-me
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=false

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLAN_NAME=Vanta Pilot Pro
STRIPE_PLAN_PRICE=R199
STRIPE_PLAN_INTERVAL=month
